# Copy this file to .env and fill in your real values.
# Get a free OpenRouter API key at https://openrouter.ai (no card required).

OPENROUTER_API_KEY=your-openrouter-api-key-here

# "openrouter/free" auto-selects an available free model for each request
# (and prefers a vision-capable one automatically when a photo is attached).
# You can pin a specific model instead, e.g. google/gemma-4-31b-it:free
OPENROUTER_MODEL=openrouter/free

# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed frontend origin, for example:
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
